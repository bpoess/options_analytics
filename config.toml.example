# Example config for options_analytics.
# Copy this file to config.toml and replace placeholder values.

version = 1

[etrade]

[[etrade.accounts]]
# Display label for an E*TRADE account.
label = "Primary Individual"
# E*TRADE account ID.
id = "123456789"

[[etrade.accounts]]
# You can add additional account blocks as needed.
label = "Business LLC"
id = "987654321"

[etrade.key]
# E*TRADE API consumer key from the developer portal.
api = "your_etrade_api_key"
# E*TRADE API consumer secret from the developer portal.
secret = "your_etrade_api_secret"
